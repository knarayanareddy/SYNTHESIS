# Synthesis API server — FastAPI stub for Phase 3
FROM python:3.11-slim
WORKDIR /app
COPY src/ /app/src/
COPY pyproject.toml /app/
RUN pip install --no-cache-dir -e .
EXPOSE 8787
HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8787/health')"
CMD ["python", "-m", "uvicorn", "synthesis.apps.api.main:app", "--host", "0.0.0.0", "--port", "8787"]
